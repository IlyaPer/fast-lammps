units           metal
dimension	    3
boundary	    p s p
atom_style	    atomic
neighbor	    0.3 bin
neigh_modify    delay 0 check yes

variable        lattice_constant equal 7.04
variable        inital_length equal 20*${lattice_constant}
variable        delta_y equal 0.00025

lattice		    fcc ${lattice_constant}
region		    box block 0 3 0 3 0 3 units lattice
create_box	    2 box
create_atoms	2 box

#pair_style      eam/alloy
#pair_coeff      * * Mishin-Ni-Al-2009.eam.alloy Ni

#pair_style      none
pair_style      lj/cut 7.5
#pair_coeff      1 1 0.5 2.28
#pair_coeff      1 2 0.4713 3.42
#pair_coeff      2 2 1.3333 4.56

pair_coeff      1 1 0.5  2.28
pair_coeff      2 2 0.01 4.56   
pair_coeff      1 2 0.001 3.42

mass		    1 58.6934
mass            2 469.5472


region          crack block INF 7 9 12 0 INF units lattice

#fix             1 all box/relax iso 0.0 vmax 0.0005
minimize        1.0e-8 1.0e-8 10000 100000
#timestep        0.0025
#unfix           1

#velocity        all create 100
#fix             relax all nvt temp 0.001 0.001 0.1
thermo          500
#run             1
#unfix           relax

thermo          250
#neigh_modify    every 2 delay 0 check yes

#delete_atoms    region crack

region          top block INF INF 18 INF INF INF units lattice
region          bot block INF INF INF 2 INF INF units lattice
group           top region top
group           bot region bot
group           boundary union top bot
group           mobile subtract all boundary
#velocity	    mobile create 0.01 887723 temp new


compute         stress_atom all stress/atom NULL
compute         pe_atom all pe/atom
variable        vol_avg equal "vol / count(all)"
variable        stressx atom "c_stress_atom[1] / v_vol_avg * 160.218"
variable        vonMises atom "sqrt( ((c_stress_atom[1]-c_stress_atom[2])^2 + (c_stress_atom[2]-c_stress_atom[3])^2 + (c_stress_atom[3]-c_stress_atom[1])^2 + 6*(c_stress_atom[4]^2 + c_stress_atom[5]^2 + c_stress_atom[6]^2)) / 2 ) / v_vol_avg * 160.218"
dump            1 all custom 250 TEST_APPROXIMATED_CRACK_dump_accurate.crack_GRAIN.lammpstrj id type x y z fx fy fz v_stressx v_vonMises c_pe_atom
dump_modify     1 sort id

fix             1 top    setforce 0.0 0.0 0.0
fix             2 bot    setforce 0.0 0.0 0.0

#fix             my_deform all deform 1 y erate 0.001 units box remap v
thermo_modify   lost ignore
#write_dump      all custom TEST_APPROXIMATED_CRACK_dump_accurate.crack_GRAIN.lammpstrj id type x y z
run 500
#run 12000