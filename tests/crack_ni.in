units           metal
dimension	    3
boundary	    s s p

atom_style	    atomic
neighbor	    0.3 bin
neigh_modify    delay 0 check yes

variable        lattice_constant equal 3.52
variable        inital_length equal 20*${lattice_constant}
variable        delta_y equal 0.00025

lattice		    fcc ${lattice_constant}
region		    box block 0 20 0 20 0 20 units lattice
create_box	    1 box
create_atoms	1 box

#pair_style      eam/alloy
#pair_coeff      * * tests/Mishin-Ni-Al-2009.eam.alloy Ni

pair_style      lj/cut 7.5
pair_coeff      1 1 0.3729 2.2808

mass		    1 58.6934


#compute         peratom all stress/atom pair viria       
#compute         fy all reduce sum & 
#c_peratom[1]    c_peratom[2] c_peratom[3] & 
#c_peratom[4]    c_peratom[5] c_peratom[6]
#peratom         all stress/atom pair virial 
#compute         p all reduce sum c_peratom[1] c_peratom[2] c_peratom[3]
#variable        press equal -(c_p[1]+c_p[2]+c_p[3])/(3*vol)
#run 0
#variable        ly0 equal ly
#
#variable        strain_yy equal (ly-v_ly0)/v_ly0
#variable        vol equal vol
#
#compute         peratom all stress/atom pair virial
#compute         p all reduce sum c_peratom[1] c_peratom[2] c_peratom[3]
#variable        sigma_yy equal -c_p[2]/v_vol*160.218
#
#thermo_style    custom step ly vol v_strain v_sigmavolume temp etotal press v_press 

#variable        sigmavolume equal c_fy[2]/vol
#variable        strain equal (ly-v_L)/v_L
#
#run 0
#variable bulkpe equal pe
#variable N_bulk equal count(all)
#variable E_bulk_atom equal ${bulkpe}/${N_bulk}
#
#variable area   equal "lx*ly"
#variable gamma  equal ((${slabpe}-${N_surf}*${E_bulk_atom})/(2*${area}))

 
#variable        crack_length equals 7*${lattice_constant} # C0
region          crack block INF 7 9 12 0 INF units lattice
#
#compute stress  all stress/atom NULL
#compute pz all  reduce sum c_stress[3]         
#variable stress_z equal -c_pz/vol/10000.0      
#variable strain_z equal (lz-v_L0)/v_L0         

#change_box     all x delta -5.0 5.0 y delta -5.0 5.0 z delta -5.0 5.0

minimize        1.0e-8 1.0e-8 10000 100000
timestep        0.0025

velocity        all create 0.1 511124 dist gaussian rot yes mom yes
fix             relax all nvt temp 0.1 300 1.0
thermo          500
run             500
unfix           relax

thermo          250
neigh_modify    every 2 delay 0 check yes

delete_atoms    region crack

region          top block INF INF 18 INF INF INF units lattice
region          bot block INF INF INF 2 INF INF units lattice
group           top region top
group           bot region bot
group           boundary union top bot
group           mobile subtract all boundary
#velocity	    mobile create 0.01 887723 temp new


compute         stress_atom all stress/atom NULL
variable        vol_avg equal "vol / count(all)"
variable        stressx atom "c_stress_atom[1] / v_vol_avg * 160.218"
variable        vonMises atom "sqrt( ((c_stress_atom[1]-c_stress_atom[2])^2 + (c_stress_atom[2]-c_stress_atom[3])^2 + (c_stress_atom[3]-c_stress_atom[1])^2 + 6*(c_stress_atom[4]^2 + c_stress_atom[5]^2 + c_stress_atom[6]^2)) / 2 ) / v_vol_avg * 160.218"
dump            1 all custom 500 dump.crack.lammpstrj id type x y z fx fy fz v_stressx v_vonMises
dump_modify     1 sort id


fix             1 all nve
fix		        2 boundary setforce NULL 0.0 0.0
velocity        top set 0.0 0.1 0.0
#velocity	    mobile ramp vy 0.0 0.1 y 2 18 sum yes
velocity        bot set 0.0 -0.1 0.0


run             20000