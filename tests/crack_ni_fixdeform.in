units metal
dimension 3
boundary p s p
atom_style atomic

lattice fcc 3.52
region box block 0 20 0 20 0 20 units lattice
create_box 1 box
create_atoms 1 box

pair_style eam
pair_coeff * * tests/Ni_u3.eam
mass 1 58.69

# --- трещина ---
region crack block 0 13 9 11 INF INF units lattice
delete_atoms region crack

# --- релаксация ---
velocity all create 300 12345
fix 1 all nvt temp 300 300 0.1
run 5000
unfix 1

# --- деформация ---
variable erate equal 5e-5

fix 1 all nve
fix def all deform 1 x erate ${erate} units box remap x

thermo 250
run 15000